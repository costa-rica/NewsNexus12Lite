{
  "name": "@newsnexus12lite/api",
  "version": "0.1.0",
  "private": true,
  "description": "Express TypeScript API for NewsNexus12Lite",
  "main": "dist/src/server.js",
  "scripts": {
    "dev": "TS_NODE_FILES=true node --env-file=.env --watch -r ts-node/register src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env dist/src/server.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.ts\"",
    "seed": "ts-node scripts/seed-defaults.ts"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "cookie-parser": "^1.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^10.0.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "jest": "^30.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0"
  }
}
