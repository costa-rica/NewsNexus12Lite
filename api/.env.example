# NewsNexus12Lite API configuration
PORT=8010

# Lite Postgres connection string. Passwordless local trust auth is expected.
DATABASE_URL=postgres://newsnexus12lite_user@localhost:5432/newsnexus12lite

# Pipeline execution mode: mock or live.
PIPELINE_MODE=mock

# Required only when PIPELINE_MODE=live.
AI_API_KEY=

# Optional mock pipeline delay. Later phases may interpret this as a fixed value
# or as the default 400-900 ms range when omitted.
MOCK_STAGE_DELAY_MS=

# Optional global rate limit overrides.
HOURLY_RATE_LIMIT=200
DAILY_RATE_LIMIT=1000
